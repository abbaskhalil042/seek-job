# ===== Server =====
NODE_ENV=development
PORT=5050
API_PREFIX=/api/v1
CLIENT_URL=http://localhost:3000

# ===== Database =====
MONGODB_URI=mongodb://127.0.0.1:27017/seek-job

# ===== JWT =====
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===== File Uploads =====
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# ===== LLM (Resume Parsing) =====
# Provider options: gemini | groq | openrouter | none
# If LLM_API_KEY is empty, the app falls back to a built-in heuristic parser.
LLM_PROVIDER=gemini
LLM_API_KEY=
# Default models per provider (override if you like):
#   gemini     -> gemini-2.0-flash
#   groq       -> llama-3.3-70b-versatile
#   openrouter -> meta-llama/llama-3.1-8b-instruct:free
LLM_MODEL=gemini-2.0-flash

# ===== Rate Limiting =====
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
